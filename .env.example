# ════════════════════════════════════════════════════════════
# SkillMaster AI - Environment Variables
# Copy this file to .env and fill in your values
# ════════════════════════════════════════════════════════════

# ─── General ───────────────────────────────────────────────
NODE_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:8000
BFF_URL=http://localhost:4000

# ─── Supabase / PostgreSQL ─────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/skillmaster
SUPABASE_URL=http://localhost:54321
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ─── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── MongoDB ───────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/skillmaster

# ─── Auth (NextAuth.js v5) ─────────────────────────────────
AUTH_SECRET=generate-a-random-secret-here
AUTH_URL=http://localhost:3000

# ─── Google OAuth ──────────────────────────────────────────
AUTH_GOOGLE_ID=your-google-client-id
AUTH_GOOGLE_SECRET=your-google-client-secret

# ─── GitHub OAuth ──────────────────────────────────────────
AUTH_GITHUB_ID=your-github-client-id
AUTH_GITHUB_SECRET=your-github-client-secret

# ─── AI Services ──────────────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key
OPENAI_API_KEY=your-openai-api-key
GOOGLE_AI_API_KEY=your-google-ai-api-key

# ─── Vector DB (Pinecone) ─────────────────────────────────
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_ENVIRONMENT=your-pinecone-environment
PINECONE_INDEX=skillmaster-embeddings

# ─── Elasticsearch ─────────────────────────────────────────
ELASTICSEARCH_URL=http://localhost:9200

# ─── Voice AI ──────────────────────────────────────────────
ELEVENLABS_API_KEY=your-elevenlabs-api-key

# ─── Stripe ────────────────────────────────────────────────
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret

# ─── S3 / R2 Storage ──────────────────────────────────────
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=skillmaster-media
AWS_REGION=us-east-1

# ─── Blockchain ───────────────────────────────────────────
POLYGON_RPC_URL=https://rpc-mumbai.maticvigil.com
DEPLOYER_PRIVATE_KEY=your-wallet-private-key

# ─── Kafka ─────────────────────────────────────────────────
KAFKA_BROKERS=localhost:9092

# ─── Observability ─────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
POSTHOG_API_KEY=your-posthog-api-key
