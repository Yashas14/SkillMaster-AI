{
  "name": "@skillmaster/bff",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format cjs --dts",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "express": "^4.21.0",
    "cors": "^2.8.5",
    "helmet": "^8.0.0",
    "morgan": "^1.10.0",
    "http-proxy-middleware": "^3.0.0",
    "express-rate-limit": "^7.4.0",
    "compression": "^1.7.0",
    "zod": "^3.24.0",
    "socket.io": "^4.8.0",
    "redis": "^4.7.0",
    "@skillmaster/types": "workspace:*"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/cors": "^2.8.0",
    "@types/morgan": "^1.9.0",
    "@types/compression": "^1.7.0",
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0",
    "tsx": "^4.19.0",
    "tsup": "^8.3.0",
    "vitest": "^2.1.0",
    "rimraf": "^6.0.0"
  }
}
